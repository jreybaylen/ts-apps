{
  "name": "back-end",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --minify-whitespace --minify-syntax --target=bun --outdir=dist",
    "start": "bun dist/index.js",

    "fmt": "oxfmt .",
    "lint": "oxlint --fix ."
  },
  "dependencies": {
    "elysia": "^1.4.27"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0"
  },
  "module": "src/index.ts"
}

{
  "name": "hydra-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "cd .. && husky hydra-app/.husky",
    "clean": "del-cli \"dist\" \"node_modules\"",
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc -b && vite build",
    "test": "vitest",
    "test:ci": "vitest --run",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "oxlint": "oxlint .",
    "oxlint:fix": "oxlint --fix .",
    "oxfmt": "oxfmt ."
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
